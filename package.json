{
  "name": "new-earthworm",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "pm:start": "pm2 start ecosystem.config.js",
    "lint": "next lint",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "docker:start": "docker-compose up -d",
    "docker:mysql": "bash scripts/run-mysql-docker.sh",
    "docker:stop": "docker-compose stop",
    "db:init": "node scripts/ensure-node18.js && npx prisma migrate dev && node scripts/createCourses.js && node scripts/uploadCourseData.js",
    "db:update": "node scripts/ensure-node18.js && node scripts/createCourses.js && node scripts/uploadCourseData.js",
    "migrate:courses-json": "node scripts/migrateCourseJsonToPinyin.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "5.22.0",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-toast": "^1.1.5",
    "argon2": "^0.31.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "iron-session": "^8.0.1",
    "lucide-react": "^0.292.0",
    "next": "14.0.3",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.49.2",
    "react-use": "^17.4.0",
    "sharp": "^0.33.0",
    "tailwind-merge": "^2.0.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.22.4",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "dotenv": "^16.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.3",
    "pdf-parse": "^1.1.1",
    "postcss": "^8",
    "prisma": "5.22.0",
    "pinyin-pro": "^3.27.0",
    "vitest": "^2.1.9",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
