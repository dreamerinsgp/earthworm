// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"] //  <---- important to support Prisma Query engine in Alpine linux, otherwise "PrismaClientInitializationError2 [PrismaClientInitializationError]: Query engine binary for current platform "linux-musl" could not be found."
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id           Int            @id @default(autoincrement())
  title        String
  statements   Statement[]
  UserProgress UserProgress[]

  @@map("courses")
}

model Statement {
  id           Int     @id @default(autoincrement())
  order        Int     @unique
  chinese      String
  /// Space-separated answer key (toneless or any style; compared via normalizePinyin)
  pinyin       String  @db.VarChar(512)
  /// Tone-marked pinyin shown after reveal
  soundmark    String  @db.VarChar(512)
  /// Optional English translation on answer screen
  englishGloss String? @db.VarChar(512)
  courseId     Int?
  courses      Course? @relation(fields: [courseId], references: [id])

  @@index([courseId], map: "Statement_courseId_fkey")
  @@map("statements")
}

model UserProgress {
  id             Int     @id @default(autoincrement())
  courseId       Int
  statementIndex Int
  active         Boolean
  courses        Course? @relation(fields: [courseId], references: [id])
  userId         Int
}
